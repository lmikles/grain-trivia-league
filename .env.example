# ---------------------------------------------------------------
# Grain Trivia League — environment variables
# Copy this to .env.local for local Vercel dev (vercel dev).
# Add these as Environment Variables in your Vercel project settings.
# ---------------------------------------------------------------

# Google Sheets
# The ID in the sheet URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Full contents of the service account JSON key file, as a single-line string.
# In Vercel dashboard paste the entire JSON value; it handles the escaping.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"trivia-league@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ---------------------------------------------------------------
# Auth secrets
# ---------------------------------------------------------------

# Admin secret — full access, can pick any location.
# Share only with the league administrator.
HOST_SECRET=change_me_to_a_long_random_string

# Per-store host secrets — each store gets its own key.
# When a host logs in with one of these, their location is set automatically.
MAIN_STREET_SECRET=change_me_main_street
EXCHANGE_SECRET=change_me_exchange
H2O_SECRET=change_me_h2o

# Anthropic API key for the trivia question generator.
ANTHROPIC_API_KEY=sk-ant-...
